SEGMENT_A=(os_icon)
SEGMENT_B=(cwd_component)
SEGMENT_C=(git_component)

SEGMENT_X=() # python_component node_component
SEGMENT_Y=()
SEGMENT_Z=()

segment() {
  local name=$1; shift
  case "$name" in
    Z) name="A" ;;
    Y) name="B" ;;
    X) name="C" ;;
  esac

  local fgvar="seg${name}fg"
  local bgvar="seg${name}bg"
  local sepvar="seg${name}sep"
  local fg=${(P)fgvar:-}
  local bg=${(P)bgvar:-}
  local sep=${(P)sepvar:-}
  local comps=("$@")

  local content=""
  local i=1
  for comp in "${comps[@]}"; do
    local val=$($comp)
    [[ -n $val ]] && content+=" $val "
    if (( i < ${#comps[@]} )); then
      content+="%F{$sep}|%F{$fg}"
    fi
    ((i++))
  done

  echo "%K{$bg}%F{$fg}${content}%f%k"
}

left() {
  local left

  for seg in A B C; do
    local arrname="SEGMENT_${seg}"
    local comps=("${(@P)arrname}")    # expand the array variable named in $arrname
    [[ ${#comps[@]} -gt 0 ]] && left+=$(segment $seg "${comps[@]}")
  done

  echo $left
}

right() {
  local right

  for seg in X Y Z; do
    local arrname="SEGMENT_${seg}"
    local comps=("${(@P)arrname}")
    [[ ${#comps[@]} -gt 0 ]] && right+=$(segment $seg "${comps[@]}")
  done

  echo $right
}

precmd_vcs_info() { vcs_info }

+vi-git-check() {
 if [[ $(git rev-parse --is-inside-work-tree 2> /dev/null) == 'true' ]]; then
  UNPUSHED=$(git log --oneline @{u}.. 2> /dev/null | wc -l)
  if [[ -n $UNPUSHED ]] && [[ $UNPUSHED != '0' ]]; then
   hook_com[misc]+=$(echo " ŌćĪ$UNPUSHED")
  fi
  UNPULLED=$(git log --oneline ..@{u} 2> /dev/null | wc -l)
  if [[ -n $UNPULLED ]] && [[ $UNPULLED != '0' ]]; then
   hook_com[misc]+=$(echo " ŌćŻ$UNPULLED")
  fi

  GIT_STATUS=$(git status --porcelain)
  # Staged files
  STAGED=$(echo $GIT_STATUS | grep -v '??' | grep -v "^ " | grep -v "^$" | wc -l) 
  if [[ -n $STAGED ]] && [[ $STAGED != '0' ]]; then
   hook_com[misc]+=" %F{green}+$STAGED%f"
  fi
  # Unstaged files
  UNSTAGED=$(echo $GIT_STATUS | grep -v '??' | grep "^ " | wc -l) 
  if [[ -n $UNSTAGED ]] && [[ $UNSTAGED != '0' ]]; then
   hook_com[misc]+=" %F{red}!$UNSTAGED%f"
  fi
  # Untracked files
  UNTRACKED=$(echo $GIT_STATUS | grep '??' | wc -l) 
  if [[ -n $UNTRACKED ]] && [[ $UNTRACKED != '0' ]]; then
   hook_com[misc]+=" %F{yellow} ŌćŻ ?$UNTRACKED%f"
  fi
 fi
}

basic() {

  autoload -Uz add-zsh-hook
  autoload -Uz vcs_info 
  add-zsh-hook precmd prompt_precmd
  add-zsh-hook precmd precmd_vcs_info
  setopt prompt_subst

	zstyle ':vcs_info:git:*' formats 'ŅéĀ %b %m'
	zstyle ':vcs_info:git:*' actionformats 'ŅéĀ %b|%a %m'
	zstyle ':vcs_info:git*+set-message:*' hooks git-check

  PROMPT='$(left)%f%k %F{blue}>%f '
  RPROMPT='$(right)%f%k'
}

basic
