os_icon() {
  local icon
  case "$OSTYPE" in
    linux*)
      if [[ -r /etc/os-release ]]; then
        local id=$(grep -E '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
        case "$id" in
          ubuntu)   icon="’īø " ;;   # Ubuntu
          debian)   icon="’īå " ;;   # Debian
          arch)     icon="’īā " ;;   # Arch
          fedora)   icon="’īŖ " ;;   # Fedora
          centos)   icon="’īä " ;;   # CentOS
          rhel)     icon="’ī¢ " ;;   # RHEL
          manjaro)  icon="’īÆ " ;;   # Manjaro
          opensuse*|sles) icon="’īö " ;; # openSUSE / SLES
          alpine)   icon="’īĆ " ;;   # Alpine
          *)        icon="Ņ£Æ " ;;   # fallback for unknown Linux
        esac
      else
        icon="Ņ£Æ "
      fi
      ;;
    darwin*)   icon="’īé " ;;   # macOS
    freebsd*)  icon="’īī " ;;   # FreeBSD
    *)         icon="­¤Æ╗" ;;
  esac

  local container_icon=""
	if [ -f /run/.toolboxenv ]; then
	  container_icon="ŅĖø "
	elif [ -f /run/.containerenv ]; then
		container_icon="’ÆĘ "
	elif [ -f /run/.dockerinit ]; then
		container_icon="’īł "
	fi

  echo "$container_icon$icon"
}

